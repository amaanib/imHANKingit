# State-by-state VAR(1) decomposition
# Estimating A separately for each state; iterate IRF.

run_var_state <- function(st) {
  d_s <- d_var |> filter(uf_code == st) |> arrange(date)
  fit <- try(fit_A(d_s), silent = TRUE)
  if (inherits(fit, "try-error") || any(!is.finite(fit$A))) {
    return(tibble(uf_code = st, horizon = 0:12,
                  mp_shock = NA_real_, log_c = NA_real_))
  }
  compute_irf(fit$A, H = 12) |> mutate(uf_code = st)
}

irf_state <- lapply(sort(unique(panel$uf_code)), run_var_state) |> bind_rows()
write.csv(irf_state, "irf_var1_state_by_state.csv", row.names = FALSE)

