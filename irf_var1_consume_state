# 2. Panel VAR(1) setup

fit_A <- function(d) {
  use_month_fe <- n_distinct(d$month_num) > 1
  use_year_fe  <- n_distinct(d$year)      > 1
  use_uf_fe    <- n_distinct(d$uf_code)   > 1

  rhs <- c("lag_mp_shock", "lag_log_c")
  if (use_uf_fe)    rhs <- c(rhs, "factor(uf_code)")
  if (use_month_fe) rhs <- c(rhs, "factor(month_num)")
  if (use_year_fe)  rhs <- c(rhs, "factor(year)")

  f1 <- as.formula(paste("mp_shock ~", paste(rhs, collapse = " + ")))
  f2 <- as.formula(paste("log_c    ~", paste(rhs, collapse = " + ")))

  eq1 <- lm(f1, data = d)
  eq2 <- lm(f2, data = d)

  A <- matrix(
    c(coef(eq1)["lag_mp_shock"], coef(eq1)["lag_log_c"],
      coef(eq2)["lag_mp_shock"], coef(eq2)["lag_log_c"]),
    nrow = 2, byrow = TRUE,
    dimnames = list(c("mp_shock", "log_c"),
                    c("lag_mp_shock", "lag_log_c"))
  )
  list(A = A, eq1 = eq1, eq2 = eq2)
}

compute_irf <- function(A, H = 12) {
  e   <- c(1, 0)                                      # unit shock to mp_shock
  out <- matrix(NA_real_, nrow = H + 1, ncol = 2,
                dimnames = list(NULL, c("mp_shock", "log_c")))
  out[1, ] <- e
  Ah <- diag(2)
  for (h in seq_len(H)) {
    Ah         <- Ah %*% A
    out[h + 1, ] <- Ah %*% e
  }
  as_tibble(out) |>
    mutate(horizon = 0:H) |>
    select(horizon, mp_shock, log_c)
}

fit       <- fit_A(d_var)
A_hat     <- fit$A
irf_point <- compute_irf(A_hat, H = 12)

A_hat
irf_point

# Cluster bootstrap over states for 95% CI +
# Resample states with replacement (27 per draw), re-estimate A, re-iterate IRF.

set.seed(123)
B <- 500
states_vec <- sort(unique(d_var$uf_code))

boot_irfs <- vector("list", B)

for (b in seq_len(B)) {
  sampled <- sample(states_vec, size = length(states_vec), replace = TRUE)
  d_b <- bind_rows(lapply(seq_along(sampled), function(k) {
    d_var |>
      filter(uf_code == sampled[k]) |>
      mutate(uf_code = 10000L + k)   # unique id so FEs are not collapsed across draws
  }))

  A_b <- try(fit_A(d_b)$A, silent = TRUE)
  if (inherits(A_b, "try-error") || any(!is.finite(A_b))) {
    boot_irfs[[b]] <- NULL
    next
  }
  boot_irfs[[b]] <- compute_irf(A_b, H = 12) |> mutate(b = b)
}

boot_df <- bind_rows(boot_irfs)

irf_ci <- boot_df |>
  group_by(horizon) |>
  summarize(
    lo95_mp = quantile(mp_shock, 0.025, na.rm = TRUE),
    hi95_mp = quantile(mp_shock, 0.975, na.rm = TRUE),
    lo95_c  = quantile(log_c,    0.025, na.rm = TRUE),
    hi95_c  = quantile(log_c,    0.975, na.rm = TRUE),
    .groups = "drop"
  )

irf_var <- irf_point |> left_join(irf_ci, by = "horizon")

write.csv(irf_var, "irf_var1_consume_state_bootstrap.csv", row.names = FALSE)
irf_var

