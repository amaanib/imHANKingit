# State-by-state LP decomposition

run_lp_state_h <- function(st, h) {
  d <- panel |>
    filter(uf_code == st) |>
    arrange(date) |>
    mutate(
      y_lead = dplyr::lead(log_c, h),
      y_resp = y_lead - lag_log_c
    ) |>
    filter(!is.na(y_resp), !is.na(lag_log_c), !is.na(lag_mp_shock))

  use_month_fe <- n_distinct(d$month_num) > 1
  use_year_fe  <- n_distinct(d$year) > 1

  rhs <- c(
    "mp_shock",
    "lag_log_c",
    "lag_mp_shock"
  )
  if (use_month_fe) rhs <- c(rhs, "factor(month_num)")
  if (use_year_fe)  rhs <- c(rhs, "factor(year)")

  fml <- as.formula(paste("y_resp ~", paste(rhs, collapse = " + ")))
  m   <- lm(fml, data = d)

  Vnw <- NeweyWest(m, lag = max(1, h), prewhite = FALSE, adjust = TRUE)
  ct  <- coeftest(m, vcov. = Vnw)

  mp <- safe_get(ct, "mp_shock")

  tibble(
    uf_code = st,
    horizon = h,
    n_obs   = nobs(m),
    beta_mp = mp[1],
    se_mp   = mp[2],
    lo95_mp = beta_mp - 1.96 * se_mp,
    hi95_mp = beta_mp + 1.96 * se_mp
  )
}

states <- sort(unique(panel$uf_code))

irf_state <- crossing(uf_code = states, horizon = horizons) |>
  mutate(res = map2(uf_code, horizon, run_lp_state_h)) |>
  pull(res) |>
  list_rbind()

write.csv(irf_state, "irf_state_by_state_consume_state.csv", row.names = FALSE)

irf_state |>
  group_by(uf_code) |>
  summarize(min_obs = min(n_obs), max_obs = max(n_obs), .groups = "drop")

